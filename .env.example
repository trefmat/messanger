# ──────────────────────────────────────────────
# Chat Security Configuration
# ──────────────────────────────────────────────

# Server configuration
# Node.js app should run behind Nginx on an internal port
PORT=3000
NODE_ENV=production

# JWT Secret (generate a strong random string, min 32 characters)
# Example: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-change-me

# Initial admin bootstrap password (used only when users.json is empty)
# Must include lower/upper/digit/special char
# Default password "ChangeMe123!" is blocked by server startup checks
ADMIN_PASSWORD=ChangeMe_Strong_123!

# Password policy
MIN_PASSWORD_LENGTH=6

# Allowed origins for CORS (comma-separated)
ALLOWED_ORIGINS=https://browsermessage.run.place,https://www.browsermessage.run.place,http://localhost:3000

# Logging
LOG_LEVEL=info
