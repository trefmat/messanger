# ──────────────────────────────────────────────
# Chat Security Configuration
# ──────────────────────────────────────────────

# Server configuration
PORT=443
NODE_ENV=production

# JWT Secret (generate a strong random string, min 32 characters)
# Example: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-change-me

# Allowed origins for CORS (comma-separated)
ALLOWED_ORIGINS=https://browsermessage.run.place,http://localhost:443

# SSL Certificate paths (for HTTPS)
SSL_KEY_PATH=/etc/letsencrypt/live/browsermessage.run.place/privkey.pem
SSL_CERT_PATH=/etc/letsencrypt/live/browsermessage.run.place/fullchain.pem

# Logging
LOG_LEVEL=info
